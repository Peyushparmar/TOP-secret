# Copy this file to .env and fill in your real values
# Never commit .env to Git

ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXX
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-location-id
GHL_WEBHOOK_SECRET=your-webhook-secret
GHL_PIPELINE_ID=your-pipeline-id
GHL_STAGE_NEW=your-stage-id-new
GHL_STAGE_CONTACTED=your-stage-id-contacted
GHL_STAGE_NURTURING=your-stage-id-nurturing
GHL_STAGE_QUALIFIED=your-stage-id-qualified
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
SENDGRID_API_KEY=SG.XXXXXXXXXXXX
BLAND_API_KEY=your-bland-api-key
FB_PAGE_ACCESS_TOKEN=your-fb-page-token
FB_VERIFY_TOKEN=your-fb-verify-token

# Dashboard Login (generate hash with: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())")
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=your-bcrypt-hash-here
FLASK_SECRET_KEY=generate-a-random-64-char-string
